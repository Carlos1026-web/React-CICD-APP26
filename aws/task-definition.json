{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "my-react-task-definition-json-20260330",
    "containerDefinitions": [
        {
            "name": "my-react-image",
            "image": "806169617511.dkr.ecr.us-east-1.amazonaws.com/my-react-app:latest",

            "portMappings": [
                {
                    "name": "ngnix-80-tcp",
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],

            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::806169617511:role/ecsTaskExecutionRole"
}